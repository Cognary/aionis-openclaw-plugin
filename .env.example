AIONIS_BASE_URL=http://127.0.0.1:3001
AIONIS_API_KEY=replace_with_your_key
AIONIS_TENANT_ID=default
AIONIS_SCOPE=default
AIONIS_SCOPE_PREFIX=clawbot
AIONIS_SCOPE_MODE=project
AIONIS_USER_ID=default
AIONIS_ACTOR=openclaw-aionis-plugin
AIONIS_PRESET=compact
AIONIS_AUTO_RECALL=true
AIONIS_AUTO_CAPTURE=true
AIONIS_AUTO_POLICY_FEEDBACK=true
